mc = mean(mc),
markup = mean(markup),
cs_market = mean(cs_market),
cs_indiv = mean(cs_indiv))
res_cf_market$cs_pax <- res_cf_market$cs_market / res_cf_market$pax
ret_list <- list("res_cf_market" = res_cf_market,
"res_cf" = res_cf,
"df_cf" = df_cf)
return(ret_list)
}
get_merger_wave <- function (df_in,
est_list,
party1_1,
party1_2,
party2_1,
party2_2,
party3_1,
party3_2,
year_in,
case = "favorable") {
df_cf <- update_merger_fun(df_in  = df_in,
party1 = party1_1,
party2 = party1_2,
delta  = est_list$delta,
xi     = est_list$xi,
omega  = est_list$omega,
case   = case)
df_cf <- update_merger_fun(df_in  = df_cf,
party1 = party2_1,
party2 = party2_2,
delta  = df_cf$delta,
xi     = df_cf$xi,
omega  = df_cf$omega,
case   = case)
df_cf <- update_merger_fun(df_in  = df_cf,
party1 = party3_1,
party2 = party3_2,
delta  = df_cf$delta,
xi     = df_cf$xi,
omega  = df_cf$omega,
case   = case)
correct_dummies <- function (df_in,
party1,
party2) {
party1_l <- tolower(party1)
party2_l <- tolower(party2)
ind_1 <- which(colnames(df_in) == party1_l)
ind_2 <- which(colnames(df_in) == party2_l)
ind_3 <- which(colnames(df_in) == paste0(party1_l,
party2_l))
df_in[, c(ind_1, ind_2)] <- 0
df_in[, ind_3] <- as.numeric(df_in$firm == party1)
return(df_in)
}
df_cf <- correct_dummies(df_in = df_cf,
party1 = party1_1,
party2 = party1_2)
df_cf <- correct_dummies(df_in = df_cf,
party1 = party2_1,
party2 = party2_2)
df_cf <- correct_dummies(df_in = df_cf,
party1 = party3_1,
party2 = party3_2)
blp_list_cf <- update_blp_data_short(blp_data = df_cf,
demand_spec = est_list$demand_spec,
supply_spec = est_list$supply_spec)
own_mk_cf <- matrix(NA, nrow(df_cf), length(unique(df_cf$firm)))
for (j in 1:ncol(own_mk_cf)) {
own_mk_cf[, j] <- as.numeric(df_cf$firm == unique(df_cf$firm)[j])
}
x1 <- blp_list_cf$X1
x1_tmp <- x1[, - which(colnames(x1) %in% c("price", "lwgshare"))]
beta <- est_list$d_coefs
beta_tmp <- beta[- which(names(beta) %in% c("price", "lwgshare"))]
df_cf$delta_tilde <- x1_tmp %*% beta_tmp + df_cf$xi
df_cf$mc <- blp_list_cf$X2 %*% est_list$s_coefs + df_cf$omega
out_cf <- get_cf_prices(alpha           = est_list$alpha,
sigma           = est_list$sigma,
delta_tilde     = df_cf$delta_tilde,
mc              = df_cf$mc,
market_vec      = unique(df_cf$mk_id),
market_vec_long = df_cf$mk_id,
prices          = df_cf$price,
own_mk          = own_mk_cf,
group_id        = df_cf$market,
diff_max        = 1e-03,
iter_max        = 100)
x1_tmp <- x1[, - which(colnames(x1) %in% c("lwgshare"))]
x1_tmp[, which(colnames(x1_tmp) == "price")] <- out_cf$prices
df_cf$price_cf <- out_cf$prices
beta_tmp <- beta[- which(names(beta) %in% c("lwgshare"))]
delta_cf <- x1_tmp %*% beta_tmp + df_cf$xi
df_cf$pax_cf <- out_cf$shares * df_cf$marketsize
cs_cf <- get_cs(market_index = df_cf$market,
msize        = df_cf$marketsize,
delta        = delta_cf,
alpha        = est_list$alpha,
sigma        = est_list$sigma)
res_cf <- data.frame("market" = df_cf$market,
"firm" = df_cf$firm,
"pax" = out_cf$shares * df_cf$marketsize,
"price" = out_cf$prices,
"mc" = df_cf$mc,
"markup" = out_cf$markup,
stringsAsFactors = F)
res_cf <- res_cf %>%
left_join(cs_cf,
by = "market")
res_cf <- res_cf[substr(res_cf$market, 1, 4) == year_in, ]
res_cf_market <- res_cf %>%
group_by(market) %>%
summarize(pax = sum(pax),
price = mean(price),
mc = mean(mc),
markup = mean(markup),
cs_market = mean(cs_market),
cs_indiv = mean(cs_indiv))
res_cf_market$cs_pax <- res_cf_market$cs_market / res_cf_market$pax
ret_list <- list("res_cf_market" = res_cf_market,
"res_cf" = res_cf,
"df_cf" = df_cf)
return(ret_list)
}
myformat <- function(variable) {
return(formatC(variable,
format = "f",
digits = 2))
}
# Baseline ----
cs_base <- get_cs(market_index = blp_data$market,
msize        = blp_data$marketsize,
delta        = est_list$delta,
alpha        = est_list$alpha,
sigma        = est_list$sigma)
res_base <- data.frame("market" = blp_data$market,
"firm"   = blp_data$firm,
"pax"    = blp_data$pax,
"price"  = blp_data$price,
"mc"     = est_list$mc,
"markup" = est_list$markup,
stringsAsFactors = F)
res_base <- res_base %>%
left_join(cs_base,
by = "market")
res_base <- res_base[substr(res_base$market, 1, 4) == "2006", ]
res_base_market <- res_base %>%
group_by(market) %>%
summarize(pax = sum(pax),
price = mean(price),
mc = mean(mc),
markup = mean(markup),
cs_market = mean(cs_market),
cs_indiv = mean(cs_indiv))
res_base_market$cs_pax <- res_base_market$cs_market / res_base_market$pax
cs_total_base <-
sum(cs_base$cs_market[substr(cs_base$market, 1, 4) == 2006]) / 1e06
cs_pax_base <- mean(res_base_market$cs_pax)
list_base <- list("cs_base" = cs_base,
"res_base_market" = res_base_market,
"blp_data" = blp_data,
"est_list" = est_list)
# Individual merger ----
list_dlnw <- get_single_merger(df_in = blp_data,
