pop_n <-
sum(df_pop$pop_2022[df_pop$fips %in% unique(df$stfips[df$uscr %in% 1:6])])
benefit_s <- delta_le_s * vsly * pop_s / 1e9
benefit_n <- delta_le_n * vsly * pop_n / 1e9
