cs_total_uaco <- sum(list_uaco$res_cf_market$cs_market) / 1e06
cs_total_aaus <- sum(list_aaus$res_cf_market$cs_market) / 1e06
delta_dlnw <- cs_total_dlnw - cs_total_base
delta_uaco <- cs_total_uaco - cs_total_base
delta_aaus <- cs_total_aaus - cs_total_base
sum(delta_dlnw + delta_uaco + delta_aaus)
