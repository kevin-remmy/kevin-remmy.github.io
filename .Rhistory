setwd("/Users/kevinremmy/Dropbox/Teaching/EMEE_2025/Lab/data/")
df <- data.frame(fread("climate_mortality.csv"))[, -1]
# Descriptive Analysis ----
# a.
df_avg_t_m <- df %>%
group_by(month) %>%
summarize(ave_temp = mean(ave_temp))
ggplot(data = df_avg_t_m, aes(x = month, y = ave_temp)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = seq(1, 12, 1),
labels = as.character(seq(1, 12, 1)),
limits = c(1, 12))
df_avg_d_m <- df %>%
group_by(month) %>%
summarize(ave_drate = mean(drate_6599))
ggplot(data = df_avg_d_m, aes(x = month, y = ave_drate)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = seq(1, 12, 1),
labels = as.character(seq(1, 12, 1)),
limits = c(1, 12))
# b.
df_avg_t_y <- df %>%
group_by(year) %>%
summarize(ave_temp = mean(ave_temp))
ggplot(data = df_avg_t_y, aes(x = year, y = ave_temp)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = seq(min(df_avg_t_y$year),
max(df_avg_t_y$year),
5),
labels = as.character(seq(min(df_avg_t_y$year),
max(df_avg_t_y$year),
5)),
limits = c(min(df_avg_t_y$year),
max(df_avg_t_y$year)))
df_avg_d_y <- df %>%
group_by(year) %>%
summarize(ave_drate = mean(drate_6599))
ggplot(data = df_avg_d_y, aes(x = year, y = ave_drate)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = seq(min(df_avg_d_y$year),
max(df_avg_d_y$year),
5),
labels = as.character(seq(min(df_avg_d_y$year),
max(df_avg_d_y$year),
5)),
limits = c(min(df_avg_d_y$year),
max(df_avg_d_y$year)))
# c.
df_state_temp <- df %>%
group_by(stfips) %>%
summarize(ave_temp = mean(ave_temp)) %>%
ungroup() %>%
rename(fips = stfips)
pal <- rev(brewer.pal(9, "RdBu"))
temp_map <-
plot_usmap(data = df_state_temp,
regions = 'state', #change this to "county" if fips is at county level
values = 'ave_temp' #name of variable that defines the colors
) + scale_fill_gradientn(
colors = pal, na.value = "gray80",
) +
labs(fill = 'Avg. Temperature') # Make the scale label more informative
print(temp_map)
df_state_drate <- df %>%
group_by(stfips) %>%
summarize(drate = mean(drate_6599)) %>%
ungroup() %>%
rename(fips = stfips)
drate_map <-
plot_usmap(data = df_state_drate,
regions = 'state', #change this to "county" if fips is at county level
values = 'drate' #name of variable that defines the colors
) + scale_fill_gradientn(
colors = pal, na.value = "gray80",
) +
labs(fill = 'Mortality rate') # Make the scale label more informative
print(drate_map)
# Cross-sectional Correlations ----
# a.
binsreg(
y = drate_6599, x = ave_temp, # y is the dependent variable, x is the independent variable.
data = df, # the dataset containing the variables
nbins = 15 # an option specifying the number of bins
)
# b.
binsreg(
y = drate_6599, x = ave_temp, # y is the dependent variable, x is the independent variable.
data = df, # the dataset containing the variables
w =  df[, c("uscr", "year")],
nbins = 15 # an option specifying the number of bins
)
# Causal Analysis ----
# a.
df$state_month <- paste0(df$stfips, "-", df$month)
df$year_month <- paste0(df$year, "-", df$month)
out_reg1 <- feols(
data = df,
fml = ln_drate_6599 ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
summary(out_reg1)
# d.
out_reg2 <- feols(
data = df,
fml = ln_drate_6599 ~ ave_temp +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
summary(out_reg2)
# e.
out_reg_s6080 <- feols(
data = df[df$year %in% c(1960:1980) & df$uscr %in% c(7:9), ],
fml = ln_drate_6599 ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
out_reg_s8104 <- feols(
data = df[df$year %in% c(1981:2004) & df$uscr %in% c(7:9), ],
fml = ln_drate_6599 ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
out_reg_n6080 <- feols(
data = df[df$year %in% c(1960:1980) & df$uscr %in% c(1:6), ],
fml = ln_drate_6599 ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
out_reg_n8104 <- feols(
data = df[df$year %in% c(1981:2004) & df$uscr %in% c(1:6), ],
fml = ln_drate_6599 ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
etable(list(out_reg_s6080,
out_reg_s8104,
out_reg_n6080,
out_reg_n8104))
# Placebo tests ----
out_reg_p <- feols(
data = df,
fml = drate_idf ~ days_below40 + days_8089 + days_above90 +
devp25 + devp75 | state_month + year_month,
cluster = ~stfips
)
summary(out_reg_p)
# Predicted values including fixed effects ----
pred_drate_s <- mean(exp(predict(out_reg_s8104)))
pred_drate_n <- mean(exp(predict(out_reg_n8104)))
# Predicted values assuming relationship weakens by 20%, south ----
coef_orig <- coef(out_reg_s8104)
# Only scale the climate-related variables
climate_vars <- c("days_above90")
comp_vars <- c("days_below40", "days_8089", "days_above90", "devp25", "devp75")
coef_scaled <- coef_orig
coef_scaled[climate_vars] <- 0.5 * coef_scaled[climate_vars]  # reduce by 10%
# Subset the original data used in the model
df_sample <- df[df$year %in% 1981:2004 & df$uscr %in% 7:9, ]
# Matrix of regressors
X <- model.matrix(out_reg_s8104, df_sample)
# New linear predictor = X %*% scaled coefficients + fixed effects
# fixest stores fixed effects separately in "fixef"
fe_contrib <- fixef(out_reg_s8104)
# Compute FE contribution for each observation
fe_vector <- rep(0, nrow(df_sample))
for (fe_name in names(fe_contrib)) {
fe_vector <- fe_vector + fe_contrib[[fe_name]][as.character(df_sample[[fe_name]])]
}
# Predicted log mortality with scaled coefficients
pred_ln_drate_scaled <- X[, comp_vars] %*% coef_scaled[comp_vars] + fe_vector
# Back to original scale
pred_drate_cf_s <- mean(exp(pred_ln_drate_scaled))
# Predicted values assuming relationship weakens by 20%, south ----
coef_orig <- coef(out_reg_n8104)
# Only scale the climate-related variables
climate_vars <- c("days_above90")
comp_vars <- c("days_below40", "days_8089", "days_above90", "devp25", "devp75")
coef_scaled <- coef_orig
coef_scaled[climate_vars] <- 0.5 * coef_scaled[climate_vars]  # reduce by 10%
# Subset the original data used in the model
df_sample <- df[df$year %in% 1981:2004 & df$uscr %in% 1:6, ]
# Matrix of regressors
X <- model.matrix(out_reg_n8104, df_sample)
# New linear predictor = X %*% scaled coefficients + fixed effects
# fixest stores fixed effects separately in "fixef"
fe_contrib <- fixef(out_reg_n8104)
# Compute FE contribution for each observation
fe_vector <- rep(0, nrow(df_sample))
for (fe_name in names(fe_contrib)) {
fe_vector <- fe_vector + fe_contrib[[fe_name]][as.character(df_sample[[fe_name]])]
}
# Predicted log mortality with scaled coefficients
pred_ln_drate_scaled <- X[, comp_vars] %*% coef_scaled[comp_vars] + fe_vector
# Back to original scale
pred_drate_cf_n <- mean(exp(pred_ln_drate_scaled))
# Calculation of life expectancy ----
beta <- 0.085        # Gompertz aging rate per year
max_age <- 120       # maximum age for integration
# function to compute the implied pooled 65+ rate for given alpha
pooled_rate_fn <- function(alpha) {
# numerator: expected deaths
deaths <- integrate(function(x) alpha *
exp(beta * (x-65)) *
surv_gompertz(x, alpha, beta),
lower = 65,
upper = max_age)$value
# denominator: person-years
py <- integrate(function(x) surv_gompertz(x, alpha, beta),
lower = 65,
upper = max_age)$value
deaths / py
}
# Gompertz survival function given alpha
surv_gompertz <- function(x, alpha, beta) {
exp(-(alpha / beta) * (exp(beta * (x - 65)) - 1))
}
get_life_exp_65 <- function (pooled_rate,
beta,
max_age) {
# convert pooled monthly rate to annual per-person rate
pooled_annual <- (12 * pooled_rate) / 100000
alpha_est <- uniroot(function(a) pooled_rate_fn(a) - pooled_annual,
lower = 0, upper = 1)$root
e65 <- integral(function(x) surv_gompertz(x, alpha_est, beta), 65, max_age)
return(e65)
}
# Get counterfactual life expectancies, south ----
le_base_s <- get_life_exp_65(pooled_rate = pred_drate_s,
beta = beta,
max_age = max_age)
le_cf_s <- get_life_exp_65(pooled_rate = pred_drate_cf_s,
beta = beta,
max_age = max_age)
delta_le_s <- le_cf_s - le_base_s
# Get counterfactual life expectancies, north ----
le_base_n <- get_life_exp_65(pooled_rate = pred_drate_n,
beta = beta,
max_age = max_age)
le_cf_n <- get_life_exp_65(pooled_rate = pred_drate_cf_n,
beta = beta,
max_age = max_age)
delta_le_n <- le_cf_n - le_base_n
# Benefits calculation ----
