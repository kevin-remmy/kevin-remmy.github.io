# Functions ----
myformat <- function(variable) {
return(formatC(variable,
format = "f",
digits = 2))
}
get_base_res <- function (list_in,
name_in) {
cs_total_base <-
sum(list_in$cs_base$cs_market[substr(list_in$cs_base$market, 1, 4) == 2006])
cs_pax_base <- mean(list_in$res_base_market$cs_pax)
price_base <- mean(list_in$blp_data$price[list_in$blp_data$year == 2006])
markup_base <- mean(list_in$est_list$markups[list_in$blp_data$year == 2006])
mc_base <- mean(list_in$est_list$mc[list_in$blp_data$year == 2006])
pax_base <- sum(list_in$blp_data$pax[list_in$blp_data$year == 2006])
res_base <- data.frame("Variable" = c("Consumer surplus: total",
"Consumer surplus: per pax",
"Price",
"Marginal cost",
"Markup",
"Passengers"),
name_in = c(cs_total_base,
cs_pax_base,
price_base * 100,
mc_base * 100,
markup_base * 100,
pax_base))
colnames(res_base)[2] <- name_in
return(res_base)
}
get_cf_res <- function (list_in,
name_in) {
cs_pax_in <- mean(list_in$res_cf_market$cs_pax)
price_in <- mean(list_in$df_cf$price_cf[list_in$df_cf$year == 2006])
mc_in <- mean(list_in$df_cf$mc[list_in$df_cf$year == 2006])
markup_in <- price_in - mc_in
pax_in <- sum(list_in$df_cf$pax_cf[list_in$df_cf$year == 2006])
res_in <- data.frame("Variable" = c("Consumer surplus: total",
"Consumer surplus: per pax",
"Price",
"Marginal cost",
"Markup",
"Passengers"),
name_in = c(sum(list_in$res_cf_market$cs_market),
cs_pax_in,
price_in * 100,
mc_in * 100,
markup_in * 100,
pax_in))
colnames(res_in)[2] <- name_in
return(res_in)
}
get_cf_cum_res <- function (list_1,
list_2,
list_3,
name_in) {
cs_total <- sum(list_1$res_cf_market$cs_market) +
sum(list_2$res_cf_market$cs_market) +
sum(list_3$res_cf_market$cs_market)
cs_pax_in <- mean(c(list_1$res_cf_market$cs_pax,
list_2$res_cf_market$cs_pax,
list_3$res_cf_market$cs_pax))
price_in <- mean(c(list_1$df_cf$price_cf[list_1$df_cf$year == 2006],
list_2$df_cf$price_cf[list_2$df_cf$year == 2006],
list_3$df_cf$price_cf[list_3$df_cf$year == 2006]))
mc_in <- mean(c(list_1$df_cf$mc[list_1$df_cf$year == 2006],
list_2$df_cf$mc[list_2$df_cf$year == 2006],
list_3$df_cf$mc[list_3$df_cf$year == 2006]))
markup_in <- mean(c(list_1$df_cf$price_cf[list_1$df_cf$year == 2006],
list_2$df_cf$price_cf[list_2$df_cf$year == 2006],
list_3$df_cf$price_cf[list_3$df_cf$year == 2006]) -
c(list_1$df_cf$mc[list_1$df_cf$year == 2006],
list_2$df_cf$mc[list_2$df_cf$year == 2006],
list_3$df_cf$mc[list_3$df_cf$year == 2006]))
pax_in <- mean(c(sum(list_1$df_cf$pax_cf[list_1$df_cf$year == 2006]),
sum(list_2$df_cf$pax_cf[list_2$df_cf$year == 2006]),
sum(list_3$df_cf$pax_cf[list_3$df_cf$year == 2006])))
res_in <- data.frame("Variable" = c("Consumer surplus: total",
"Consumer surplus: per pax",
"Price",
"Marginal cost",
"Markup",
"Passengers"),
name_in = c(cs_total,
cs_pax_in,
price_in * 100,
mc_in * 100,
markup_in * 100,
pax_in))
colnames(res_in)[2] <- name_in
return(res_in)
}
res_base <- get_base_res(list_in = list_base,
name_in = "Baseline")
res_dlnw_fav <- get_cf_res(list_in = list_dlnw_fav,
name_in = "DL/NW")
res_uaco_fav <- get_cf_res(list_in = list_uaco_fav,
name_in = "UA/CO")
res_aaus_fav <- get_cf_res(list_in = list_aaus_fav,
name_in = "AA/US")
res_cum_fav <- get_cf_cum_res(list_1 = list_dlnw_fav,
list_2 = list_uaco_fav,
list_3 = list_aaus_fav,
name_in = "Cumul.")
res_wave_fav <- get_cf_res(list_in = list_wave_fav,
name_in = "Wave")
res_fav <- res_base %>%
left_join(res_dlnw_fav,
by = "Variable") %>%
left_join(res_uaco_fav,
by = "Variable") %>%
left_join(res_aaus_fav,
by = "Variable") %>%
left_join(res_cum_fav,
by = "Variable") %>%
left_join(res_wave_fav,
by = "Variable")
res_fav[, 3:5] <- res_fav[, 3:5] - res_fav$Baseline
res_fav$Wave <- res_fav$Wave - res_fav$Baseline
res_fav$Cumul. <- rowSums(res_fav[, 3:5])
View(res_fav)
res_fav[, - 1] <- apply(res_fav[, -1], 2,
function (x) c(prettyNum(x[1],
big.mark = ","),
myformat(x[2]),
myformat(x[3]),
myformat(x[4]),
myformat(x[5]),
prettyNum(x[6],
big.mark = ",")))
res_fav[ , - c(1:2)] <- lapply(res_fav[ , - c(1:2)],
function(x) ifelse(x > 0,
paste0("+", x),
x))
