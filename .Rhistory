e65 <- integral(function(x) surv_gompertz(x, alpha_est, beta), 65, max_age)
return(e65)
}
# Get counterfactual life expectancies, south ----
le_base_s <- get_life_exp_65(pooled_rate = pred_drate_s,
beta = beta,
max_age = max_age)
le_cf_s <- get_life_exp_65(pooled_rate = pred_drate_cf_s,
beta = beta,
max_age = max_age)
delta_le_s <- le_cf_s - le_base_s
# Get counterfactual life expectancies, north ----
le_base_n <- get_life_exp_65(pooled_rate = pred_drate_n,
beta = beta,
max_age = max_age)
le_cf_n <- get_life_exp_65(pooled_rate = pred_drate_cf_n,
beta = beta,
max_age = max_age)
delta_le_n <- le_cf_n - le_base_n
# Benefits calculation ----
vsly <- 314000
df_pop <- statepop
df_pop$fips <- as.numeric(df_pop$fips)
pop_s <-
sum(df_pop$pop_2022[df_pop$fips %in% unique(df$stfips[df$uscr %in% 7:9])])
pop_n <-
sum(df_pop$pop_2022[df_pop$fips %in% unique(df$stfips[df$uscr %in% 1:6])])
benefit_s <- delta_le_s * vsly * pop_s / 1e9
benefit_n <- delta_le_n * vsly * pop_n / 1e9
library(ggplot2)
library(tidyverse)
library(fixest)
setwd("/Users/kevinremmy/Dropbox/Teaching/EMEE_2025/Lab/data/")
df <- data.frame(fread("huairiver.csv"))[, -1]
# Analyzing the data ----
# a.
ggplot(data = df, aes(x = pm10)) + geom_histogram()
ggplot(data = df, aes(x = life_exp)) + geom_histogram()
# b.
ggplot(data = df, aes(x = pm10, y = life_exp)) +
geom_point() + # Makes scatter plot
geom_smooth(method = 'lm', se = FALSE)
# c.
ggplot(data = df[- which(df$pm10 == max(df$pm10)), ],
aes(x = pm10, y = life_exp)) +
geom_point() + # Makes scatter plot
geom_smooth(method = 'lm', se = FALSE)
# d.
df <- df %>%
mutate(dist_huai_binned = floor(dist_huai))
# Calculate means within a group chosen by "group_by"
df_bins1 <- df %>% group_by(dist_huai_binned) %>%
summarize(
avg_pm10 = mean(pm10, na.rm = TRUE) #the option ignores missing values
)
ggplot(data = df_bins1,
aes(x = dist_huai_binned, y = avg_pm10)) +
geom_point()
# e.
df_bins2 <- df %>% group_by(dist_huai_binned) %>%
summarize(
avg_life_exp = mean(life_exp, na.rm = TRUE) #the option ignores missing values
)
ggplot(data = df_bins2,
aes(x = dist_huai_binned, y = avg_life_exp)) +
geom_point()
# Causal Analysis ----
# a.
regout_pm <- feols(
data = df %>% filter(dist_huai_binned <= 2 & dist_huai_binned >= -2), #choosing data subset
fml = pm10 ~ north_huai,
vcov = 'HC1' #Robust SEs
)
tau_pm <- regout_pm$coefficients['north_huai']
se_tau_pm <- regout_pm$se['north_huai']
# b.
regout_le <- feols(
data = df %>% filter(dist_huai_binned <= 2 & dist_huai_binned >= -2), #choosing data subset
fml = life_exp ~ north_huai,
vcov = 'HC1' #Robust SEs
)
tau_le <- regout_le$coefficients['north_huai']
se_tau_le <- regout_le$se['north_huai']
etable(list(regout_pm,
regout_le))
# c.
ratio_le_pm <- tau_le / tau_pm
# Robustness checks ----
# a.
regout_le_1 <- feols(
data = df %>%
filter(dist_huai_binned <= 1 &
dist_huai_binned >= - 1), #choosing data subset
fml = life_exp ~ north_huai,
vcov = 'HC1' #Robust SEs
)
regout_le_8 <- feols(
data = df %>%
filter(dist_huai_binned <= 8 &
dist_huai_binned >= - 8), #choosing data subset
fml = life_exp ~ north_huai,
vcov = 'HC1' #Robust SEs
)
etable(list(regout_le,
regout_le_1,
regout_le_8))
# b.
# bias/variance trade-off
# c.
regout_cr <- feols(
data = df %>%
filter(dist_huai_binned <= 2 &
dist_huai_binned >= - 2), #choosing data subset
fml = cmort ~ north_huai,
vcov = 'HC1' #Robust SEs
)
regout_ncr <- feols(
data = df %>%
filter(dist_huai_binned <= 2 &
dist_huai_binned >= - 2), #choosing data subset
fml = ncmort ~ north_huai,
vcov = 'HC1' #Robust SEs
)
etable(list(regout_cr,
regout_ncr))
# Benefit-Cost Analysis ----
# benefits: me of le for drop in pm10 x VSLy x population
pm_red <- 1
vsly_1 <- 314000
vsly_2 <- 20000
pop <- 1.5e09
pm_red * ratio_le_pm
library(ggplot2)
